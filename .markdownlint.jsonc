{
  // Конфиг markdownlint-cli2. Разумно ослаблен под README-стиль портфолио.
  "default": true,
  "MD013": false,   // длина строки — не ограничиваем (таблицы, ссылки)
  "MD033": false,   // inline HTML разрешён (маркеры PORTFOLIO, <details>, картинки)
  "MD041": false,   // первый заголовок не обязан быть в первой строке (у нас комментарий-переключатель языка сверху)
  "MD024": { "siblings_only": true },  // одинаковые заголовки ок, если в разных секциях
  "MD022": true,
  "MD032": true
}
